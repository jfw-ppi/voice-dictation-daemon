# Global voice dictation settings.
# Copy to ~/.config/voice-dictation.env and adjust as needed.

VOICE_DICTATION_BACKEND=local
VOICE_DICTATION_MODEL=turbo
VOICE_DICTATION_COMPUTE_TYPE=int8
VOICE_DICTATION_LANGUAGE=
VOICE_DICTATION_BEAM_SIZE=5
VOICE_DICTATION_USE_VAD=0
VOICE_DICTATION_PROMPT=
VOICE_DICTATION_HOTWORDS=
VOICE_DICTATION_OPENAI_MODEL=gpt-4o-transcribe

# Optional cloud backend:
# VOICE_DICTATION_BACKEND=openai
# VOICE_DICTATION_OPENAI_MODEL=gpt-4o-mini-transcribe

